{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "npm run build -w whirlpool-dashboard",
    "outputDirectory": "whirlpool-dashboard/dist",
    "installCommand": "npm install --legacy-peer-deps --no-package-lock",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}
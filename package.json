{
  "name": "@orca-so/whirlpools-monorepo",
  "private": true,
  "packageManager": "yarn@4.6.0",
  "type": "module",
  "scripts": {
    "build": "nx run-many --target build --projects",
    "start": "nx run-many --target start --projects",
    "test": "nx run-many --target test --projects --exclude=@orca-so/whirlpools-sdk-integration",
    "deploy": "nx run-many --target deploy --projects",
    "format": "nx run-many --target format --projects",
    "lint": "nx run-many --target lint --projects",
    "clean": "nx reset && nx run-many --target clean --projects",
    "generate": "nx run-many --target generate --projects && nx run-many --target format --projects @orca-so/whirlpools-lint,@orca-so/whirlpools-rust-client"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.2.0",
    "nx": "^23.0.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^4.0.16"
  },
  "workspaces": [
    "programs/*",
    "rust-sdk/*",
    "ts-sdk/*",
    "legacy-sdk/*",
    "examples/ts-sdk/*",
    "examples/rust-sdk/*",
    "docs/*",
    "whirlpool-dashboard"
  ],
  "dependencies": {
    "react-is": "^19.2.3",
    "vite": "^6.0.0"
  },
  "overrides": {
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4"
  }
}
